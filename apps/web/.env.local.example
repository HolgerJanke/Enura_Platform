NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_PLATFORM_ROOT_DOMAIN=enura-group.com
PLATFORM_ROOT_DOMAIN=enura-group.com
MOCK_AUTH=false
DEV_HOLDING_ADMIN=false

# Transactional email (invite/credentials). Without RESEND_API_KEY the invite
# still creates the user, but no email is sent and the admin gets the temp
# password to hand over manually. EMAIL_FROM must be on a Resend-verified domain.
RESEND_API_KEY=
EMAIL_FROM=noreply@enura-platform.com

# Dev/mock defaults — override per tenant for local development
DEV_DEFAULT_TENANT_SLUG=demo
DEV_DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000001
DEV_MOCK_EMAIL_DOMAIN=demo.enura.ch
