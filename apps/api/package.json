{
  "name": "@enura/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "email:dev": "email dev --dir src/emails --port 3002"
  },
  "dependencies": {
    "@enura/types": "workspace:*",
    "@react-email/components": "^0.0.31",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "@fastify/cors": "^9.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.1.0",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.34.8",
    "date-fns": "^4.1.0",
    "ioredis": "^5.4.2",
    "googleapis": "^144.0.0",
    "zod": "^3.23.8",
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "@fastify/rate-limit": "^10.2.1",
    "@sentry/node": "^8.48.0"
  },
  "devDependencies": {
    "@enura/config": "workspace:*",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.31.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
